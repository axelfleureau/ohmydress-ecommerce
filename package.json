{
  "name": "nrmlss",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "bootstrap:cloudflare": "node scripts/bootstrap-cloudflare.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply ohmydress-ecommerce --local",
    "db:migrate:remote": "wrangler d1 migrations apply ohmydress-ecommerce --remote",
    "import:products": "node scripts/import-shopify-products.mjs",
    "import:theme": "node scripts/import-shopify-theme.mjs",
    "import:theme-home": "node scripts/import-shopify-theme-home.mjs",
    "seed:site-content": "node scripts/seed-site-content.mjs",
    "commerce:services:start": "node scripts/commerce-services.mjs start",
    "commerce:services:stop": "node scripts/commerce-services.mjs stop",
    "commerce:services:status": "node scripts/commerce-services.mjs status",
    "commerce:build": "npm run build --workspace=@dtc/backend --prefix apps/commerce",
    "commerce:migrate": "cd apps/commerce/apps/backend && ../../node_modules/.bin/medusa db:migrate",
    "commerce:dev": "npm run backend:dev --prefix apps/commerce",
    "commerce:user": "cd apps/commerce/apps/backend && ../../node_modules/.bin/medusa user",
    "commerce:export-products": "node scripts/export-medusa-products.mjs",
    "commerce:import-products": "npm run commerce:export-products && cd apps/commerce/apps/backend && ../../node_modules/.bin/medusa exec ./src/scripts/import-ohmydress-products.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@opennextjs/cloudflare": "^1.19.11",
    "gsap": "^3.14.2",
    "lenis": "^1.3.16",
    "next": "^16.2.4",
    "next-transition-router": "^0.2.11",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-icons": "^5.5.0",
    "three": "0.158.0",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "wrangler": "^4.97.0"
  }
}
